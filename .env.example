# ===========================================================================
# Konfigurasi Backend IDN Cyber Range
# Salin file ini menjadi `.env` lalu sesuaikan nilainya.
# ===========================================================================

# Koneksi database MySQL (Prisma)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/idn_cyber_range"

# Port HTTP server Express
PORT=4000

# Origin frontend yang diizinkan mengakses API (CORS).
# Catatan: di mode development (NODE_ENV != production), CORS otomatis
# memantulkan origin apa pun agar mudah diakses dari komputer lain di LAN.
# Nilai di bawah dipakai saat PRODUKSI. Boleh beberapa (pisah koma),
# atau "*" untuk mengizinkan semua origin.
CORS_ORIGIN="http://localhost:3000"

# ---------------------------------------------------------------------------
# Rahasia JWT — WAJIB diganti dengan string acak yang panjang & sulit ditebak.
# Inilah kunci yang dipakai menandatangani & memverifikasi token. Bila bocor,
# penyerang bisa memalsukan token apa pun (termasuk role admin).
# Buat contoh: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
# ---------------------------------------------------------------------------
JWT_SECRET="ganti-dengan-secret-acak-yang-panjang-dan-aman"
JWT_EXPIRES_IN="1d"

# Berapa kali putaran hashing bcrypt (semakin tinggi semakin aman tapi lambat)
BCRYPT_SALT_ROUNDS=10
